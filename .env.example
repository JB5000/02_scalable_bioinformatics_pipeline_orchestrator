# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/orchestrator
SQLITE_DB_PATH=data/orchestrator.db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Nextflow
NEXTFLOW_HOME=~/.nextflow
NEXTFLOW_WORK_DIR=./work
NEXTFLOW_CONFIG=nextflow.config

# AWS (if using AWS Batch)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Authentication
API_KEY_ADMIN=dev_key_admin
API_KEY_USER=dev_key_user
